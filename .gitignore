# .gitignore

# 🐍 Python & Backend Junk
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.pytest_cache/

# ⚛️ Frontend & JavaScript Blackhole
node_modules/
npm-debug.log
yarn-error.log
.eslintcache

# 🤖 Machine Learning & Jupyter
.ipynb_checkpoints/
# (Note: We are not ignoring your sample_symptoms.csv or triage_model.pkl for this hackathon so the judges can clone and run it, but in production, massive datasets go here!)

# 💻 OS Ghost Files
.DS_Store
Thumbs.db